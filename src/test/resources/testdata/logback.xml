<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Console Appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Root Logger -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>

    <!-- Application Logger - Set to INFO to see your LOG.info() messages -->
    <logger name="AddPlace" level="INFO" />
    
    <!-- RestAssured Logger - Set to INFO to see RestAssured logs -->
    <logger name="io.restassured" level="INFO" />
</configuration>


